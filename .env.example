# ==============================================================================
# CoopWork — Variaveis de Ambiente (Raiz do Monorepo)
# ==============================================================================
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NUNCA comite arquivos .env reais no repositorio.
# Referencia completa: README.md -> Setup
# ==============================================================================

NODE_ENV=development

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder
# APENAS backend — nunca expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder-service-role

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Redis — local: docker run -d -p 6379:6379 redis | producao: Railway add-on
REDIS_URL=redis://localhost:6379

# Anthropic Claude API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-replace-with-real-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# URLs da aplicacao
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
PORT=3001

# E-mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@cooperativa.coop.br
