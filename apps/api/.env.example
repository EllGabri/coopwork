# ==============================================================================
# CoopWork API — Variaveis de Ambiente (NestJS)
# ==============================================================================
# Copie para apps/api/.env.local e preencha com suas credenciais reais.
# NUNCA comite arquivos .env reais no repositorio.
# ==============================================================================

NODE_ENV=development
PORT=3001/

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-replace-with-real-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# E-mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@cooperativa.coop.br

# Database (PostgreSQL local — docker-compose)
DATABASE_URL=postgresql://postgres:[your-password]@db.your-project-id.supabase.co:5432/postgres
