# ==============================================================================
# CoopWork API — Variaveis de Ambiente (NestJS)
# ==============================================================================
# Copie para apps/api/.env.local e preencha com suas credenciais reais.
# NUNCA comite arquivos .env reais no repositorio.
# ==============================================================================

NODE_ENV=development
PORT=3001

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder-service-role

# Google OAuth
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-replace-with-real-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# E-mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@cooperativa.coop.br

# Database (PostgreSQL local — docker-compose)
DATABASE_URL=postgresql://coopwork:coopwork_dev_password@localhost:5432/coopwork_dev
